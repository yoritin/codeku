{
  "name": "codeku",
  "version": "0.1.0",
  "private": true,
  "description": "Display Japanese readings for code identifiers on hover",
  "scripts": {
    "dev:extension": "pnpm --filter @codeku/extension dev",
    "build:extension": "pnpm --filter @codeku/extension build",
    "package:extension": "pnpm --filter @codeku/extension package",
    "dev:web": "pnpm --filter @codeku/web dev",
    "build:web": "pnpm --filter @codeku/web build",
    "test": "pnpm --filter @codeku/extension test",
    "lint": "pnpm -r lint"
  },
  "keywords": [
    "vscode",
    "extension",
    "japanese",
    "reading",
    "pronunciation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
